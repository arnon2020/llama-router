# llama-router Environment Variables
# Copy this file to .env and customize as needed

# Docker Compose Settings
COMPOSE_PROJECT_NAME=llamarouter

# NVIDIA GPU Settings
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility

# Memory Limits (adjust based on your GPU VRAM)
# llama-router container memory limit
LLAMA_ROUTER_MEM_LIMIT=12g

# API Settings
# External port for llama-router API (default: 8581)
LLAMA_API_PORT=8581

# Web UI Settings
# External port for web UI (default: 8580)
WEB_UI_PORT=8580

# llama.cpp Server Settings
# Maximum number of models loaded concurrently
MODELS_MAX=5

# Number of parallel requests
PARALLEL_REQUESTS=4

# Context size for models (default: 8192)
CTX_SIZE=8192

# GPU layers (99 = offload all to GPU)
N_GPU_LAYERS=99

# Temperature (default: 0.7)
TEMPERATURE=0.7

# Top-p sampling (default: 0.9)
TOP_P=0.9

# Min-p sampling (default: 0.05)
MIN_P=0.05

# KV Cache quantization (q4_0 recommended)
CTK=q4_0

# Tensor KV cache quantization
CTV=q4_0

# Thread count (default: 16)
THREADS=16

# Enable flash attention (true/false)
FLASH_ATTENTION=true

# Enable jinja templates (true/false)
JINJA=true

# Enable continuous batching (true/false)
CONT_BATCHING=true

# Enable mmap (true/false) - set to false for better performance
MMAP=false

# Model Directory
MODELS_DIR=./models

# Config File Path
CONFIG_PATH=./config.ini
